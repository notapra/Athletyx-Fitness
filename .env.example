# Supabase — copy to .env and fill in your project values
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Public app config only (safe to copy to .env.local) ---
# API keys belong in PRIVATE.env — see SECRETS.md (never commit PRIVATE.env)

# Athletyx backend URL (Vite dev proxies /api/athletyx → localhost:8000)
# VITE_ATHLETYX_API_URL=/api/athletyx
