# =============================================================================
# PRIVATE.env — YOUR SECRETS ONLY (NEVER COMMIT THIS FILE)
# =============================================================================
# Copy to PRIVATE.env and fill in values. PRIVATE.env is gitignored.
# API keys stay on the server (Athletyx backend) — never use VITE_ prefix
# (Vite exposes VITE_* to the browser).
# =============================================================================

# OpenAI — optional; enables LLM coaching in IronLog (gpt-4o-mini)
OPENAI_API_KEY=

# SerpAPI — DuckDuckGo / Google web research for IronCoach
# https://serpapi.com/search.json?engine=duckduckgo
SERPAPI_API_KEY=
SERPAPI_HL=en
SERPAPI_GL=us
# SERPAPI_LOCATION=Austin, Texas, United States
