# Pick ONE setup and copy matching values into .env:
#
# A) docker compose up -d  (see docker-compose.yml, port 5432)
# B) Postgres.app          https://postgresapp.com  (port 5432)
# C) Supabase local CLI    supabase start           (port 54322)
# D) Supabase cloud        Project Settings → Database → connection string
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# MCP client scoping (set in .cursor/mcp.json env, not usually in .env)
# ATHLETYX_USER_ID=1
# ATHLETYX_ADMIN=false

# SerpAPI — web search (search_web_serpapi / search_web_duckduckgo)
# Endpoint: https://serpapi.com/search.json
# Get a key at https://serpapi.com/ — paste into .env only, never commit .env
SERPAPI_API_KEY=
# Optional for engine=google:
# SERPAPI_LOCATION=Austin, Texas, United States
SERPAPI_HL=en
SERPAPI_GL=us
